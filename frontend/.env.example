VITE_BACKEND_URL=http://localhost:3001

# --- EVM / Ethereum Sepolia (Zama fhEVM target) ---
VITE_EVM_RPC_URL=https://eth-sepolia.public.blastapi.io
VITE_EVM_CHAIN_ID=11155111

# Deployed Crackd contract addresses (Sepolia)
VITE_CRACKD_DUEL_ADDRESS=
VITE_CRACKD_VAULT_ADDRESS=
VITE_CRACKD_FHE_ADDRESS=

# Stake-token ERC20 addresses (Sepolia)
VITE_USDC_ADDRESS=
VITE_WETH_ADDRESS=

# Zama confidential relayer (powers the CrackdFHE engine)
VITE_RELAYER_URL=https://relayer.testnet.zama.org

# Privy app id (https://dashboard.privy.io). Leave blank to disable
# email/social sign-in; the injected crypto-wallet path still works without it.
VITE_PRIVY_APP_ID=

# WalletConnect / Reown project id (free at https://cloud.reown.com). Enables the
# "WalletConnect" option for mobile + hundreds of wallets via QR. Leave blank to
# hide it; installed browser wallets (MetaMask, Coinbase, Rabby, …) still show.
VITE_WALLETCONNECT_PROJECT_ID=
