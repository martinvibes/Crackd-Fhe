# --- Crackd Confidential (fhEVM / Zama) contract deployment ---

# Sepolia RPC (Zama fhEVM testnet target). Alchemy/Infura/public all work.
SEPOLIA_RPC_URL=https://eth-sepolia.public.blastapi.io

# Deployer / admin key. This account becomes the owner of CrackdDuel & CrackdVault
# (the backend signs resolution txs with the same key). 0x-prefixed, 64 hex chars.
ADMIN_PRIVATE_KEY=0xyour_private_key_here

# Optional: contract verification on Etherscan.
ETHERSCAN_API_KEY=
