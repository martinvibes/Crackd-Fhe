{
  "name": "crackd-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Crackd backend — game orchestration, EVM contract calls (Zama fhEVM), Claude AI opponent.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
