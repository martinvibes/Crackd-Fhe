# --- Server ---
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
# Comma-separated list of allowed origins. Vite picks the next free port
# when 5173 is taken (5174, 5175, …) so include a few defaults for dev.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# --- EVM (Zama fhEVM on Ethereum Sepolia) ---
EVM_NETWORK=sepolia
# Any Sepolia JSON-RPC endpoint (Alchemy, Infura, public node, …).
EVM_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
EVM_CHAIN_ID=11155111
# Admin signer — 0x + 64 hex chars. NEVER commit. Load from your keystore.
ADMIN_PRIVATE_KEY=
# Admin address — 0x + 40 hex chars (must match ADMIN_PRIVATE_KEY).
ADMIN_ADDRESS=
# ERC-20 token addresses (Sepolia). WETH=18 decimals, USDC=6 decimals.
WETH_ADDRESS=
USDC_ADDRESS=
SUPPORTED_ASSETS=WETH,USDC
# Deployed Crackd contract addresses (see contracts/deployments).
CRACKD_VAULT_ADDRESS=
CRACKD_DUEL_ADDRESS=
CRACKD_FHE_ADDRESS=
# Zama relayer — used by the frontend for FHE encrypt/decrypt. The backend
# includes it for completeness but generally does not call it.
RELAYER_URL=https://relayer.testnet.zama.org

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=200

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Game ---
GAME_SESSION_TTL_SECONDS=7200
CHAT_RATE_LIMIT_MS=3000
TAUNT_RATE_LIMIT_MS=30000
